# Frontend public values. NOT secret — these are exposed to the browser.
# Copy to .env locally if you want to keep them out of frontend/js/config.js,
# or just edit frontend/js/config.js directly (the simpler option for static hosting).

# Backend URL (Render service URL).
# Example: https://pulse-backend.onrender.com
PULSE_API_BASE=

# Google OAuth Client ID (public; safe to ship to the browser).
VITE_GOOGLE_CLIENT_ID=
